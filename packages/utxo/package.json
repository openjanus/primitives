{
  "name": "@openjanus/utxo",
  "version": "0.1.0",
  "description": "Privacy UTXO primitive for Flow — Merkle tree + nullifiers + ZK shield/transfer/unshield. Foundation for AurumFlow-class RAILGUN-style apps.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "circuits/*.circom",
    "circuits/setup/*.zkey",
    "circuits/setup/*.json",
    "circuits/build/**/*.wasm",
    "circuits/README.md",
    "contracts/**/*.sol",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run --reporter=verbose",
    "test:unit": "vitest run tests/unit --reporter=verbose",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/integration --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "deploy": "npx tsx scripts/deploy.ts",
    "generate-setup": "npx tsx scripts/generate-setup.ts",
    "precompute-tree-zeros": "npx tsx scripts/precompute-tree-zeros.ts"
  },
  "dependencies": {
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6",
    "ethers": "^6.13.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "utxo",
    "merkle",
    "nullifier",
    "zk",
    "privacy",
    "groth16",
    "babyjub",
    "poseidon",
    "flow",
    "evm",
    "circom"
  ],
  "license": "MIT",
  "author": "oydual3 <claucondor@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/openjanus/primitives.git",
    "directory": "packages/utxo"
  }
}
